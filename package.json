{
  "name": "dlinter-ts-react",
  "version": "0.1.0",
  "description": "Deterministic architecture governance for TypeScript + React projects: custom ESLint rules, architecture-concept presets, and pre-commit gate scaffolding.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "dlinter": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "bun run typecheck && bun run test"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "react",
    "typescript",
    "architecture",
    "lint",
    "lefthook",
    "pre-commit"
  ],
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5.0.0 <6.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/utils": "^8.63.0",
    "eslint": "^10.6.0",
    "lefthook": "^2.1.10",
    "tsdown": "^0.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-doctor": "^0.7.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.1.0"
  }
}
